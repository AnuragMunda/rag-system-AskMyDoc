{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"],
      "@/api/*": ["api/*"],
      "@/shared/*": ["shared/*"],
      "@/retrieval/*": ["retrieval/*"],
      "@/ingestion/*": ["ingestion/*"],
      "@/config/*": ["config/*"]
    }
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}